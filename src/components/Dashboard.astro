---
import GroupPhaseCard from './GroupPhaseCard.astro';
import KnockoutPhaseCard from './KnockoutPhaseCard.astro';

const BACKEND_URL = import.meta.env.PUBLIC_API_URL ?? import.meta.env.URL_BACKEND ?? 'http://localhost:3000';
const DISCORD_AUTH_URL = `${BACKEND_URL}/auth/discord`;
---

<section id="hero">
  <div class="title-wrapper">
    <span class="emoji">⚽</span>
    <span class="title">Penca uruWhy 2026</span>
  </div>

  <p>Competi con tus amigos y domina el Mundial.</p>

  <div class="actions">
    <a href={DISCORD_AUTH_URL} class="btn discord" data-discord-button hidden>
      <svg viewBox="0 0 127.14 96.36" class="icon">
        <path
          fill="currentColor"
          d="M107.7 8.07A105.15 105.15 0 0 0 81.47 0a72.06 72.06 0 0 0-3.36 6.83 97.68 97.68 0 0 0-29.11 0A72.37 72.37 0 0 0 45.64 0a105.89 105.89 0 0 0-26.25 8.09C2.79 32.65-1.71 56.6.54 80.21a105.73 105.73 0 0 0 32.17 16.15 77.7 77.7 0 0 0 6.89-11.11 68.42 68.42 0 0 1-10.85-5.18c.91-.66 1.8-1.34 2.66-2a75.57 75.57 0 0 0 64.32 0c.87.71 1.76 1.39 2.66 2a68.68 68.68 0 0 1-10.87 5.19 77 77 0 0 0 6.89 11.1 105.25 105.25 0 0 0 32.19-16.14c2.64-27.38-4.51-51.11-18.9-72.15Z"
        />
      </svg>
      Conectar Discord
    </a>

    <a href="/admin" class="btn admin" data-admin-button hidden>Panel admin</a>
  </div>
</section>

<section id="tabs" class="tabs-shell">
  <div class="tabs-header">
    <button class="tab-btn active" type="button" data-tab-button="dashboard">Dashboard</button>
    <button class="tab-btn" type="button" data-tab-button="penca">Mi Penca</button>
    <button class="tab-btn" type="button" data-tab-button="resultados" hidden>Resultados</button>
  </div>

  <div class="tab-panel active" data-tab-panel="dashboard">
    <section id="grid">
      <div class="card">
        <h2>🏆 Ranking</h2>
        <ul class="data-list" data-ranking-list>
          <li>Cargando ranking...</li>
        </ul>
      </div>

      <div class="card">
        <h2>📅 Partidos</h2>
        <ul class="data-list" data-matches-list>
          <li>Cargando partidos...</li>
        </ul>
      </div>

      <div class="card">
        <h2>🌍 Paises</h2>
        <ul class="data-list" data-countries-list>
          <li>Cargando paises...</li>
        </ul>
      </div>
    </section>
  </div>

  <div class="tab-panel" data-tab-panel="penca" hidden>
    <div class="tab-panel-content tab-panel-content--penca">
      <section id="penca-board" class="penca-board">
        <GroupPhaseCard />
        <KnockoutPhaseCard />
      </section>
      <div class="penca-submit">
        <button type="button" class="btn prediction" data-submit-prediction disabled>Realizar prediccion</button>
        <p class="submit-hint" data-submit-hint>Completá grupos y eliminatoria para poder enviar.</p>
      </div>
    </div>
  </div>

  <div class="tab-panel" data-tab-panel="resultados" hidden>
    <div class="tab-panel-content tab-panel-content--resultados">
      <section class="results-board">
        <div class="results-hero card">
          <div class="results-hero-copy">
            <p class="results-kicker">Comparación oficial</p>
            <h2>Resultados</h2>
            <p class="penca-hint">Se actualiza solo cuando el admin cambia el orden real. Verde significa acierto, rojo significa error.</p>
          </div>
          <div class="results-legend">
            <span class="legend-chip legend-chip--correct" data-summary-correct>Correcto 0</span>
            <span class="legend-chip legend-chip--wrong" data-summary-wrong>Incorrecto 0</span>
            <span class="legend-chip legend-chip--pending" data-summary-pending>Pendiente 0</span>
            <span class="legend-chip legend-chip--missing" data-summary-missing>Sin definir 0</span>
          </div>
        </div>

        <div class="results-card card">
          <div class="results-card-header">
            <h3>Penca guardada</h3>
            <span class="results-card-meta" data-results-meta>Cargando resultados...</span>
          </div>
          <div class="predictions-list" data-predictions-list>
            <p class="list-item empty">Cargando pencas...</p>
          </div>
        </div>
      </section>
    </div>
  </div>
</section>

<script is:inline define:vars={{ BACKEND_URL }}>
  (() => {
  const discordButton = document.querySelector('[data-discord-button]');
  const adminButton = document.querySelector('[data-admin-button]');
  const rankingList = document.querySelector('[data-ranking-list]');
  const matchesList = document.querySelector('[data-matches-list]');
  const countriesList = document.querySelector('[data-countries-list]');
  const predictionsList = document.querySelector('[data-predictions-list]');
  const resultsMeta = document.querySelector('[data-results-meta]');
  const summaryCorrect = document.querySelector('[data-summary-correct]');
  const summaryWrong = document.querySelector('[data-summary-wrong]');
  const summaryPending = document.querySelector('[data-summary-pending]');
  const summaryMissing = document.querySelector('[data-summary-missing]');
  const predictionButton = document.querySelector('[data-submit-prediction]');
  const submitHint = document.querySelector('[data-submit-hint]');
  const tabButtons = document.querySelectorAll('[data-tab-button]');
  const tabPanels = document.querySelectorAll('[data-tab-panel]');
  const dashboardTabButton = document.querySelector('[data-tab-button="dashboard"]');
  const pencaTabButton = document.querySelector('[data-tab-button="penca"]');
  const dashboardTabPanel = document.querySelector('[data-tab-panel="dashboard"]');
  const pencaTabPanel = document.querySelector('[data-tab-panel="penca"]');
  const resultadosTabButton = document.querySelector('[data-tab-button="resultados"]');
  const resultadosTabPanel = document.querySelector('[data-tab-panel="resultados"]');
  const API_URL = BACKEND_URL;
  const ADMIN_DISCORD_ID = '179134666626826241';
  const GROUPS_ORDER = [
    'Grupo A',
    'Grupo B',
    'Grupo C',
    'Grupo D',
    'Grupo E',
    'Grupo F',
    'Grupo G',
    'Grupo H',
    'Grupo I',
    'Grupo J',
    'Grupo K',
    'Grupo L',
  ];
  const KNOCKOUT_STAGES = [
    ['r32', '16avos'],
    ['r16', 'Octavos'],
    ['qf', 'Cuartos'],
    ['sf', 'Semifinal'],
    ['final', 'Final'],
    ['champion', 'Campeón'],
  ];

  const dashboardState = {
    users: [],
    matches: [],
    countries: [],
  };

  let sessionUser = null;
  let currentPrediction = {
    groupOrder: null,
    knockout: null,
  };
  let officialResults = {
    groupOrder: null,
    knockout: null,
  };
  let savedPredictions = [];
  let lastSavedSnapshot = '';
  let autosaveTimeoutId = null;

  const createNode = (tag, className, text) => {
    const node = document.createElement(tag);

    if (className) {
      node.className = className;
    }

    if (typeof text === 'string') {
      node.textContent = text;
    }

    return node;
  };

  const renderEmptyState = (listElement, text) => {
    if (!listElement) {
      return;
    }

    listElement.innerHTML = '';
    const emptyItem = createNode('li', 'list-item empty', text);
    listElement.appendChild(emptyItem);
  };

  const formatKickoff = (kickoff) => {
    const date = new Date(kickoff);

    if (Number.isNaN(date.getTime())) {
      return 'Fecha no disponible';
    }

    return date.toLocaleString('es-UY', {
      day: '2-digit',
      month: '2-digit',
      hour: '2-digit',
      minute: '2-digit',
    });
  };

  const normalizeCode = (code) => {
    if (typeof code !== 'string') {
      return null;
    }

    const normalized = code.trim().toUpperCase();
    return normalized.length ? normalized : null;
  };

  const normalizeGroupKey = (groupName) => {
    if (typeof groupName !== 'string') {
      return null;
    }

    const raw = groupName.trim();
    if (!raw.length) {
      return null;
    }

    const match = raw.match(/(?:grupo|group)?\s*([a-l])/i);
    if (!match) {
      return raw;
    }

    return `Grupo ${match[1].toUpperCase()}`;
  };

  const normalizeGroupOrder = (groupOrder) => {
    if (!groupOrder || typeof groupOrder !== 'object' || Array.isArray(groupOrder)) {
      return null;
    }

    const entries = Object.entries(groupOrder);
    const normalized = {};

    entries.forEach(([groupName, codes]) => {
      if (!Array.isArray(codes)) {
        return;
      }

      const normalizedGroupName = normalizeGroupKey(groupName);
      if (!normalizedGroupName) {
        return;
      }

      normalized[normalizedGroupName] = codes
        .map((code) => normalizeCode(code))
        .filter((code) => Boolean(code))
        .slice(0, 4);
    });

    return Object.keys(normalized).length ? normalized : null;
  };

  const normalizeKnockout = (knockout) => {
    if (!knockout || typeof knockout !== 'object' || Array.isArray(knockout)) {
      return null;
    }

    const stages = [
      ['r32', 32],
      ['r16', 16],
      ['qf', 8],
      ['sf', 4],
      ['final', 2],
      ['champion', 1],
    ];

    const normalized = {};

    stages.forEach(([stage, size]) => {
      const source = knockout[stage];

      if (!Array.isArray(source)) {
        normalized[stage] = Array(size).fill(null);
        return;
      }

      const slots = source.slice(0, size).map((code) => normalizeCode(code));

      while (slots.length < size) {
        slots.push(null);
      }

      normalized[stage] = slots;
    });

    return normalized;
  };

  const normalizeOfficialGroupOrder = (groupOrder) => {
    if (!groupOrder || typeof groupOrder !== 'object' || Array.isArray(groupOrder)) {
      return null;
    }

    const normalized = {};

    Object.entries(groupOrder).forEach(([groupName, codes]) => {
      if (!Array.isArray(codes)) {
        return;
      }

      const normalizedGroupName = normalizeGroupKey(groupName);
      if (!normalizedGroupName) {
        return;
      }

      normalized[normalizedGroupName] = codes.slice(0, 4).map((code) => normalizeCode(code));

      while (normalized[normalizedGroupName].length < 4) {
        normalized[normalizedGroupName].push(null);
      }
    });

    return Object.keys(normalized).length ? normalized : null;
  };

  const normalizeOfficialKnockout = (knockout) => {
    if (!knockout || typeof knockout !== 'object' || Array.isArray(knockout)) {
      return null;
    }

    const stages = [
      ['r32', 32],
      ['r16', 16],
      ['qf', 8],
      ['sf', 4],
      ['final', 2],
      ['champion', 1],
    ];

    const normalized = {};

    stages.forEach(([stage, size]) => {
      const source = knockout[stage];

      if (!Array.isArray(source)) {
        normalized[stage] = Array(size).fill(null);
        return;
      }

      const slots = source.slice(0, size).map((code) => normalizeCode(code));

      while (slots.length < size) {
        slots.push(null);
      }

      normalized[stage] = slots;
    });

    return normalized;
  };

  const getCountryLabel = (code) => {
    const normalizedCode = normalizeCode(code);
    const country = dashboardState.countries.find((item) => item.code === normalizedCode);

    if (!country) {
      return normalizedCode ?? '—';
    }

    return `${country.flag} ${country.name}`;
  };

  const setOfficialResults = (results) => {
    officialResults = {
      groupOrder: normalizeOfficialGroupOrder(results?.groupOrder),
      knockout: normalizeOfficialKnockout(results?.knockout),
    };

    if (resultsMeta) {
      const updatedAt = results?.updatedAt ? new Date(results.updatedAt) : null;

      resultsMeta.textContent = updatedAt && !Number.isNaN(updatedAt.getTime())
        ? `Actualizado por Tito · ${updatedAt.toLocaleString('es-UY', {
          day: '2-digit',
          month: '2-digit',
          hour: '2-digit',
          minute: '2-digit',
        })}`
        : 'Aún no hay resultados oficiales cargados.';
    }
  };

  const isAdminUser = () => sessionUser?.discordId === ADMIN_DISCORD_ID;

  const getSlotStatus = (predictedCode, officialCode) => {
    const normalizedPredicted = normalizeCode(predictedCode);
    const normalizedOfficial = normalizeCode(officialCode);

    if (!normalizedOfficial) {
      return 'pending';
    }

    if (!normalizedPredicted) {
      return 'missing';
    }

    return normalizedPredicted === normalizedOfficial ? 'correct' : 'wrong';
  };

  const createStatusBadge = (text, status) => {
    const badge = createNode('span', 'prediction-badge prediction-chip', text);
    badge.classList.add(`prediction-chip--${status}`);
    badge.dataset.status = status;
    return badge;
  };

  const applyResultStatusStyles = (slot, badge, status) => {
    if (!slot || !badge) {
      return;
    }

    if (status === 'correct') {
      slot.style.background = 'rgba(22, 101, 52, 0.52)';
      slot.style.borderColor = 'rgba(34, 197, 94, 0.86)';
      badge.style.background = 'linear-gradient(135deg, rgba(22, 101, 52, 0.68), rgba(34, 197, 94, 0.24))';
      badge.style.borderColor = 'rgba(34, 197, 94, 0.66)';
      badge.style.color = '#dcfce7';
      return;
    }

    if (status === 'wrong') {
      slot.style.background = 'rgba(127, 29, 29, 0.52)';
      slot.style.borderColor = 'rgba(239, 68, 68, 0.86)';
      badge.style.background = 'linear-gradient(135deg, rgba(127, 29, 29, 0.68), rgba(239, 68, 68, 0.24))';
      badge.style.borderColor = 'rgba(239, 68, 68, 0.66)';
      badge.style.color = '#fee2e2';
      return;
    }

    if (status === 'missing') {
      slot.style.background = 'rgba(113, 63, 18, 0.4)';
      slot.style.borderColor = 'rgba(250, 204, 21, 0.48)';
      badge.style.color = '#fde68a';
      return;
    }

    slot.style.background = 'rgba(15, 23, 42, 0.56)';
    slot.style.borderColor = 'rgba(148, 163, 184, 0.28)';
  };

  const createResultSlot = (label, status, rankText = null) => {
    const item = createNode('li', 'prediction-slot group-row');
    item.dataset.status = status;
    item.classList.add(`prediction-slot--${status}`);

    if (rankText) {
      item.appendChild(createNode('span', 'group-rank', rankText));
    }

    const badge = createStatusBadge(label, status);
    applyResultStatusStyles(item, badge, status);
    item.appendChild(badge);
    return item;
  };

  const renderPredictionGroupBlock = (groupName, predictedCodes, officialCodes) => {
    const block = createNode('article', 'group-card prediction-subcard prediction-subcard--group');
    block.appendChild(createNode('h4', 'prediction-subtitle group-title', groupName));

    const list = createNode('ul', 'prediction-slot-list group-list');

    (predictedCodes ?? []).forEach((code, index) => {
      const officialCode = officialCodes?.[index] ?? null;
      const status = getSlotStatus(code, officialCode);
      const item = createResultSlot(getCountryLabel(code), status, String(index + 1));
      list.appendChild(item);
    });

    block.appendChild(list);
    return block;
  };

  const renderPredictionKnockoutBlock = (stageKey, stageLabel, predictedCodes, officialCodes) => {
    const block = createNode('article', 'group-card prediction-subcard prediction-subcard--group');
    block.appendChild(createNode('h4', 'prediction-subtitle group-title', stageLabel));

    const list = createNode('ul', 'prediction-slot-list group-list');

    (predictedCodes ?? []).forEach((code, index) => {
      const officialCode = officialCodes?.[index] ?? null;
      const status = getSlotStatus(code, officialCode);
      const item = createResultSlot(getCountryLabel(code), status);
      list.appendChild(item);
    });

    block.appendChild(list);
    return block;
  };

  const summarizePrediction = (predictedGroupOrder, predictedKnockout) => {
    const officialGroupOrder = officialResults.groupOrder ?? {};
    const officialKnockout = officialResults.knockout ?? {};
    let correct = 0;
    let wrong = 0;
    let pending = 0;
    let missing = 0;

    Object.entries(predictedGroupOrder ?? {}).forEach(([groupName, codes]) => {
      codes.forEach((code, index) => {
        const status = getSlotStatus(code, officialGroupOrder[groupName]?.[index] ?? null);

        if (status === 'correct') correct += 1;
        if (status === 'wrong') wrong += 1;
        if (status === 'pending') pending += 1;
        if (status === 'missing') missing += 1;
      });
    });

    Object.entries(predictedKnockout ?? {}).forEach(([stageKey, codes]) => {
      codes.forEach((code, index) => {
        const status = getSlotStatus(code, officialKnockout[stageKey]?.[index] ?? null);

        if (status === 'correct') correct += 1;
        if (status === 'wrong') wrong += 1;
        if (status === 'pending') pending += 1;
        if (status === 'missing') missing += 1;
      });
    });

    return { correct, wrong, pending, missing };
  };

  const renderPredictionsBoard = () => {
    if (!predictionsList) {
      return;
    }

    predictionsList.innerHTML = '';

    const visiblePrediction = (sessionUser?.discordId
      ? savedPredictions.find((item) => item.discordId === sessionUser.discordId)
      : null) ?? savedPredictions[0] ?? null;

    if (!visiblePrediction) {
      renderEmptyState(predictionsList, 'Todavía no hay resultados para mostrar.');
      return;
    }

    const fragment = document.createDocumentFragment();
    const officialGroupOrder = officialResults.groupOrder ?? {};
    const officialKnockout = officialResults.knockout ?? {};
    const storedPayload = visiblePrediction?.payload ?? {};
    const groupOrder = normalizeGroupOrder(storedPayload.groupOrder);
    const knockout = normalizeKnockout(storedPayload.knockout);

    const item = createNode('article', 'prediction-card');
    const top = createNode('div', 'prediction-card-top');
    const title = createNode('strong', 'prediction-card-title', visiblePrediction.username ?? 'Usuario desconocido');

    top.appendChild(title);
    item.appendChild(top);

    if (!groupOrder || !knockout) {
      item.appendChild(createNode('p', 'prediction-empty', 'Prediccion incompleta o invalida.'));
      fragment.appendChild(item);
      predictionsList.appendChild(fragment);
      return;
    }

    const summary = summarizePrediction(groupOrder, knockout);
    if (summaryCorrect) summaryCorrect.textContent = `Correcto ${summary.correct}`;
    if (summaryWrong) summaryWrong.textContent = `Incorrecto ${summary.wrong}`;
    if (summaryPending) summaryPending.textContent = `Pendiente ${summary.pending}`;
    if (summaryMissing) summaryMissing.textContent = `Sin definir ${summary.missing}`;

    const layout = createNode('div', 'prediction-layout');
    const groupPanel = createNode('section', 'prediction-panel');
    groupPanel.appendChild(createNode('h4', 'prediction-section-label', 'Fase de grupos'));

    const groupGrid = createNode('div', 'groups-grid results-groups-grid');
    GROUPS_ORDER.forEach((groupName) => {
      const codes = groupOrder[groupName] ?? [];
      groupGrid.appendChild(renderPredictionGroupBlock(groupName, codes, officialGroupOrder[groupName] ?? []));
    });
    groupPanel.appendChild(groupGrid);

    const knockoutPanel = createNode('section', 'prediction-panel');
    knockoutPanel.classList.add('prediction-panel--knockout');
    knockoutPanel.appendChild(createNode('h4', 'prediction-section-label', 'Eliminatoria'));

    const knockoutGrid = createNode('div', 'groups-grid results-knockout-grid-simple');
    KNOCKOUT_STAGES.forEach(([stageKey, stageLabel]) => {
      knockoutGrid.appendChild(renderPredictionKnockoutBlock(stageKey, stageLabel, knockout[stageKey], officialKnockout[stageKey] ?? []));
    });
    knockoutPanel.appendChild(knockoutGrid);

    layout.appendChild(groupPanel);
    layout.appendChild(knockoutPanel);
    item.appendChild(layout);

    fragment.appendChild(item);

    predictionsList.appendChild(fragment);
  };

  const loadOfficialResults = async () => {
    try {
      const response = await fetch(`${API_URL}/api/official-results`, { cache: 'no-store' });

      if (!response.ok) {
        throw new Error('No official results');
      }

      const data = await response.json();
      setOfficialResults(data?.officialResults);
    } catch {
      setOfficialResults(null);
    }
  };

  const loadPredictions = async () => {
    try {
      const response = await fetch(`${API_URL}/api/predictions`, { cache: 'no-store' });

      if (!response.ok) {
        throw new Error('No predictions');
      }

      const data = await response.json();
      savedPredictions = Array.isArray(data?.predictions) ? data.predictions : [];
    } catch {
      savedPredictions = [];
    }
  };

  const refreshResultsView = async () => {
    await Promise.all([loadOfficialResults(), loadPredictions()]);
    renderPredictionsBoard();
  };

  let resultsBroadcastChannel = null;
  try {
    resultsBroadcastChannel = new BroadcastChannel('penca-results');
    resultsBroadcastChannel.addEventListener('message', (event) => {
      if (event?.data?.type === 'official-results-updated') {
        void refreshResultsView();
      }
    });
  } catch {
    resultsBroadcastChannel = null;
  }
  const setCurrentPrediction = (prediction) => {
    currentPrediction = {
      groupOrder: normalizeGroupOrder(prediction?.groupOrder),
      knockout: normalizeKnockout(prediction?.knockout),
    };
  };

  const getDraftPayload = () => {
    const payload = {};

    if (currentPrediction.groupOrder) {
      payload.groupOrder = currentPrediction.groupOrder;
    }

    if (currentPrediction.knockout) {
      payload.knockout = currentPrediction.knockout;
    }

    return payload;
  };

  const queueDraftSave = () => {
    if (!sessionUser?.discordId) {
      return;
    }

    const payload = getDraftPayload();

    if (!Object.keys(payload).length) {
      return;
    }

    const snapshot = JSON.stringify(payload);

    if (snapshot === lastSavedSnapshot) {
      return;
    }

    if (autosaveTimeoutId) {
      clearTimeout(autosaveTimeoutId);
    }

    autosaveTimeoutId = setTimeout(async () => {
      try {
        const response = await fetch(`${API_URL}/api/predictions/draft`, {
          method: 'PUT',
          headers: {
            'Content-Type': 'application/json',
          },
          credentials: 'include',
          body: snapshot,
        });

        if (response.ok) {
          lastSavedSnapshot = snapshot;
        }
      } catch {
        // Ignore autosave network errors; user can still submit manually.
      }
    }, 700);
  };

  const isGroupOrderComplete = (groupOrder) => {
    if (!groupOrder || typeof groupOrder !== 'object' || Array.isArray(groupOrder)) {
      return false;
    }

    const groups = Object.values(groupOrder);

    if (groups.length !== 12) {
      return false;
    }

    return groups.every((codes) => {
      return Array.isArray(codes) && codes.length === 4 && codes.every((code) => typeof code === 'string' && code.length > 0);
    });
  };

  const isKnockoutComplete = (knockout) => {
    if (!knockout || typeof knockout !== 'object' || Array.isArray(knockout)) {
      return false;
    }

    const requiredRounds = [
      ['r32', 32],
      ['r16', 16],
      ['qf', 8],
      ['sf', 4],
      ['final', 2],
      ['champion', 1],
    ];

    return requiredRounds.every(([key, size]) => {
      const slots = knockout[key];
      return Array.isArray(slots) && slots.length === size && slots.every((code) => typeof code === 'string' && code.length > 0);
    });
  };

  const hasCompletePrediction = () => {
    const { groupOrder, knockout } = currentPrediction;
    return isGroupOrderComplete(groupOrder) && isKnockoutComplete(knockout);
  };

  const updatePredictionButtonState = () => {
    if (!predictionButton || !submitHint) {
      return;
    }

    if (!sessionUser?.discordId) {
      predictionButton.disabled = true;
      submitHint.textContent = 'Inicia sesion con Discord para enviar tu prediccion.';
      return;
    }

    const readyToSubmit = hasCompletePrediction();
    predictionButton.disabled = !readyToSubmit;
    submitHint.textContent = readyToSubmit
      ? 'Tu prediccion esta lista para enviarse.'
      : 'Completá grupos y eliminatoria para poder enviar.';
  };

  const enforceDashboardTab = () => {
    tabButtons.forEach((button) => {
      button.classList.toggle('active', button === dashboardTabButton);
    });

    tabPanels.forEach((panel) => {
      const shouldShow = panel === dashboardTabPanel;
      panel.hidden = !shouldShow;
      panel.classList.toggle('active', shouldShow);
    });
  };

  const updatePencaAccess = () => {
    const isLoggedIn = Boolean(sessionUser?.discordId);

    if (!pencaTabButton || !pencaTabPanel) {
      return;
    }

    pencaTabButton.disabled = !isLoggedIn;
    pencaTabButton.classList.toggle('is-locked', !isLoggedIn);
    pencaTabButton.title = isLoggedIn ? '' : 'Inicia sesion con Discord para acceder a Mi Penca.';

    if (!isLoggedIn) {
      pencaTabPanel.hidden = true;
      pencaTabPanel.classList.remove('active');
      enforceDashboardTab();
    }
  };

  const updateResultadosAccess = () => {
    const isLoggedIn = Boolean(sessionUser?.discordId);

    if (!resultadosTabButton || !resultadosTabPanel) {
      return;
    }

    resultadosTabButton.hidden = !isLoggedIn;
    resultadosTabButton.disabled = !isLoggedIn;

    if (!isLoggedIn) {
      resultadosTabPanel.hidden = true;
      resultadosTabPanel.classList.remove('active');

      if (resultadosTabButton.classList.contains('active')) {
        enforceDashboardTab();
      }
    }
  };

  const setupTabs = () => {
    tabButtons.forEach((button) => {
      button.addEventListener('click', () => {
        const tab = button.dataset.tabButton;

        if (tab === 'penca' && !sessionUser?.discordId) {
          alert('Necesitas iniciar sesion con Discord para acceder a Mi Penca.');
          enforceDashboardTab();
          return;
        }

        if (tab === 'resultados' && !sessionUser?.discordId) {
          alert('Necesitas iniciar sesion con Discord para acceder a Resultados.');
          enforceDashboardTab();
          return;
        }

        tabButtons.forEach((otherButton) => {
          otherButton.classList.toggle('active', otherButton === button);
        });

        tabPanels.forEach((panel) => {
          const shouldShow = panel.dataset.tabPanel === tab;
          panel.hidden = !shouldShow;
          panel.classList.toggle('active', shouldShow);
        });

        updatePredictionButtonState();

        if (tab === 'resultados') {
          void refreshResultsView();
        }
      });
    });
  };

  const setupPredictionSubmit = () => {
    if (!predictionButton) {
      return;
    }

    predictionButton.addEventListener('click', async () => {
      if (!sessionUser?.discordId) {
        alert('Necesitas iniciar sesion con Discord para enviar tu prediccion.');
        updatePredictionButtonState();
        return;
      }

      const { groupOrder, knockout } = currentPrediction;

      if (!isGroupOrderComplete(groupOrder) || !isKnockoutComplete(knockout)) {
        alert('Tu prediccion no esta completa. Revisa grupos y eliminatoria.');
        updatePredictionButtonState();
        return;
      }

      const confirmed = window.confirm('Quieres enviar realmente tu prediccion?');

      if (!confirmed) {
        return;
      }

      predictionButton.disabled = true;
      predictionButton.classList.add('is-loading');

      try {
        const response = await fetch(`${API_URL}/api/predictions`, {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
          },
          credentials: 'include',
          body: JSON.stringify({
            groupOrder,
            knockout,
          }),
        });

        if (!response.ok) {
          let errorMessage = 'No se pudo guardar la prediccion.';

          try {
            const errorBody = await response.json();
            errorMessage = errorBody?.message || errorMessage;
          } catch {
            // Ignore JSON parse errors and keep fallback message.
          }

          throw new Error(errorMessage);
        }

        alert('Prediccion enviada y guardada correctamente.');
        lastSavedSnapshot = JSON.stringify(getDraftPayload());
      } catch (error) {
        const message = error instanceof Error ? error.message : 'Error inesperado al enviar prediccion.';
        alert(message);
      } finally {
        predictionButton.classList.remove('is-loading');
        updatePredictionButtonState();
      }
    });
  };

  const initializePenca = () => {
    const countriesByCode = new Map(dashboardState.countries.map((country) => [country.code, country]));

    window.dispatchEvent(
      new CustomEvent('penca:init', {
        detail: {
          countries: dashboardState.countries,
          countriesByCode,
          initialPrediction: currentPrediction,
        },
      }),
    );
  };

  const renderRanking = (users) => {
    if (!rankingList) {
      return;
    }

    if (!users.length) {
      renderEmptyState(rankingList, 'No hay usuarios cargados.');
      return;
    }

    rankingList.innerHTML = '';
    const fragment = document.createDocumentFragment();

    users.forEach((user, index) => {
      const item = createNode('li', 'list-item ranking-item');
      const top = createNode('div', 'item-top ranking-row');

      top.appendChild(createNode('span', 'rank-badge', `#${index + 1} `));
      top.appendChild(createNode('strong', 'item-title', user.username));
      top.appendChild(createNode('span', 'points-chip', ` ${user.points} pts`));

      item.appendChild(top);
      fragment.appendChild(item);
    });

    rankingList.appendChild(fragment);
  };

  const renderMatches = (matches) => {
    if (!matchesList) {
      return;
    }

    if (!matches.length) {
      renderEmptyState(matchesList, 'No hay partidos cargados.');
      return;
    }

    matchesList.innerHTML = '';
    const fragment = document.createDocumentFragment();

    matches.forEach((match) => {
      const home = match.homeTeam ? `${match.homeTeam.flag} ${match.homeTeam.name} ` : match.homeCountryCode;
      const away = match.awayTeam ? `${match.awayTeam.flag} ${match.awayTeam.name} ` : match.awayCountryCode;

      const item = createNode('li', 'list-item match-item');
      const top = createNode('div', 'item-top');
      const bottom = createNode('div', 'item-bottom');

      top.appendChild(createNode('strong', 'item-title teams', `${home} vs ${away}`));

      if (match.score) {
        top.appendChild(createNode('span', 'score-chip', `${match.score.home}-${match.score.away}`));
      } else {
        top.appendChild(createNode('span', 'score-chip upcoming', 'Proximo'));
      }

      bottom.appendChild(createNode('span', 'item-meta', match.stage));
      bottom.appendChild(createNode('span', 'item-meta match-date', formatKickoff(match.kickoff)));

      item.appendChild(top);
      item.appendChild(bottom);
      fragment.appendChild(item);
    });

    matchesList.appendChild(fragment);
  };

  const renderCountries = (countries) => {
    if (!countriesList) {
      return;
    }

    if (!countries.length) {
      renderEmptyState(countriesList, 'No hay paises cargados.');
      return;
    }

    countriesList.innerHTML = '';
    const fragment = document.createDocumentFragment();

    countries.forEach((country) => {
      const item = createNode('li', 'list-item country-item');
      const top = createNode('div', 'item-top');

      top.appendChild(createNode('strong', 'item-title', `${country.flag} ${country.name} `));
      top.appendChild(createNode('span', 'confederation-chip', country.confederation));

      item.appendChild(top);
      fragment.appendChild(item);
    });

    countriesList.appendChild(fragment);
  };

  const authRequest = fetch(`${API_URL}/auth/me`, {
    credentials: 'include',
  })
    .then((response) => (response.ok ? response.json() : { user: null }))
    .then((data) => {
      sessionUser = data?.user ?? null;

      if (!discordButton) {
        return;
      }

      if (sessionUser?.discordId) {
        discordButton.hidden = true;
      } else {
        discordButton.hidden = false;
      }

      if (adminButton) {
        adminButton.hidden = !isAdminUser();
      }

      updateResultadosAccess();
    })
    .catch(() => {
      sessionUser = null;

      if (discordButton) {
        discordButton.hidden = true;
      }

      if (adminButton) {
        adminButton.hidden = true;
      }

      updateResultadosAccess();
    });

  const dashboardRequest = fetch(`${API_URL}/api/dashboard`)
    .then((response) => (response.ok ? response.json() : Promise.reject(new Error('No data'))))
    .then((data) => {
      dashboardState.users = data?.users ?? [];
      dashboardState.matches = data?.matches ?? [];
      dashboardState.countries = data?.countries ?? [];

      renderRanking(dashboardState.users);
      renderMatches(dashboardState.matches);
      renderCountries(dashboardState.countries);
      renderPredictionsBoard();
    })
    .catch(() => {
      renderEmptyState(rankingList, 'No se pudo cargar el ranking.');
      renderEmptyState(matchesList, 'No se pudieron cargar los partidos.');
      renderEmptyState(countriesList, 'No se pudieron cargar los paises.');
    });

  let refreshIntervalId = null;

  const predictionRequest = authRequest.then(async () => {
    if (!sessionUser?.discordId) {
      return;
    }

    try {
      const response = await fetch(`${API_URL}/api/predictions/me`, {
        credentials: 'include',
      });

      if (!response.ok) {
        return;
      }

      const data = await response.json();
      const payload = data?.prediction?.payload;

      setCurrentPrediction(payload);

      const hydratedPayload = getDraftPayload();
      if (Object.keys(hydratedPayload).length) {
        lastSavedSnapshot = JSON.stringify(hydratedPayload);
      }
    } catch {
      // Ignore hydration failures and continue with empty state.
    }
  });

  Promise.all([authRequest, dashboardRequest, predictionRequest, refreshResultsView()]).then(() => {
    setupTabs();
    setupPredictionSubmit();
    initializePenca();
    updatePencaAccess();
    updateResultadosAccess();
    updatePredictionButtonState();

    if (refreshIntervalId) {
      clearInterval(refreshIntervalId);
    }

    refreshIntervalId = setInterval(() => {
      void refreshResultsView();
    }, 15000);
  });

  window.addEventListener('focus', () => {
    void refreshResultsView();
  });

  document.addEventListener('visibilitychange', () => {
    if (document.visibilityState === 'visible') {
      void refreshResultsView();
    }
  });

  window.addEventListener('penca:groups-changed', (event) => {
    const nextGroupOrder = event.detail?.groupOrder;

    if (nextGroupOrder && typeof nextGroupOrder === 'object') {
      currentPrediction.groupOrder = nextGroupOrder;
      queueDraftSave();
    }

    updatePredictionButtonState();
  });

  window.addEventListener('penca:knockout-changed', (event) => {
    const nextKnockout = event.detail?.knockout;

    if (nextKnockout && typeof nextKnockout === 'object') {
      currentPrediction.knockout = nextKnockout;
      queueDraftSave();
    }

    updatePredictionButtonState();
  });
  })();
</script>

