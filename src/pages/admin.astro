---
import Layout from '../layouts/Layout.astro';

const BACKEND_URL = import.meta.env.PUBLIC_API_URL ?? import.meta.env.URL_BACKEND ?? 'http://localhost:3000';
---

<Layout>
  <section class="admin-shell">
    <div class="admin-hero">
      <div>
        <p class="eyebrow">Panel privado</p>
        <h1>Resultados oficiales</h1>
        <p class="admin-copy">Edita el orden real de grupos y eliminatoria. Cada cambio afecta el color de las pencas guardadas.</p>
      </div>

      <div class="admin-hero-actions">
        <a class="back-link" href="/">Volver al dashboard</a>
        <button class="save-button" type="button" data-save-results disabled>Guardar cambios</button>
      </div>
    </div>

    <div class="admin-status" data-admin-status>Verificando permisos...</div>

    <div class="admin-board" data-admin-board hidden>
      <section class="admin-card">
        <div class="card-heading">
          <h2>Fase de grupos</h2>
          <span class="card-hint">Selecciona del 1 al 4 para cada grupo.</span>
        </div>
        <div class="group-editor" data-groups-editor></div>
      </section>

      <section class="admin-card">
        <div class="card-heading">
          <h2>Eliminatoria</h2>
          <span class="card-hint">Los campos se guardan tal como los completes, incluso si faltan rondas.</span>
        </div>
        <div class="knockout-editor" data-knockout-editor></div>
      </section>
    </div>
  </section>

  <script is:inline define:vars={{ BACKEND_URL }}>
    (() => {
      const API_URL = BACKEND_URL;
      const ADMIN_DISCORD_ID = '179134666626826241';
      const SESSION_STORAGE_KEY = 'penca_session_fallback';

      const GROUPS = [
        'Grupo A',
        'Grupo B',
        'Grupo C',
        'Grupo D',
        'Grupo E',
        'Grupo F',
        'Grupo G',
        'Grupo H',
        'Grupo I',
        'Grupo J',
        'Grupo K',
        'Grupo L',
      ];

      const KNOCKOUT_STAGES = [
        { key: 'r32', label: '16avos', size: 32 },
        { key: 'r16', label: 'Octavos', size: 16 },
        { key: 'qf', label: 'Cuartos', size: 8 },
        { key: 'sf', label: 'Semifinal', size: 4 },
        { key: 'final', label: 'Final', size: 2 },
        { key: 'champion', label: 'Campeón', size: 1 },
      ];

      const statusLabel = document.querySelector('[data-admin-status]');
      const board = document.querySelector('[data-admin-board]');
      const groupsEditor = document.querySelector('[data-groups-editor]');
      const knockoutEditor = document.querySelector('[data-knockout-editor]');
      const saveButton = document.querySelector('[data-save-results]');

      let countries = [];
      let sessionUser = null;
      let officialResults = null;

      const getAuthHeaders = () => {
        try {
          const encodedSession = window.localStorage.getItem(SESSION_STORAGE_KEY);

          if (encodedSession) {
            return {
              'x-penca-session': encodedSession,
            };
          }
        } catch {
          // Ignore storage issues and continue with cookies only.
        }

        return {};
      };

      const createNode = (tag, className, text) => {
        const node = document.createElement(tag);

        if (className) {
          node.className = className;
        }

        if (typeof text === 'string') {
          node.textContent = text;
        }

        return node;
      };

      const createSelect = (value, fieldType, fieldKey, index) => {
        const select = document.createElement('select');
        select.className = 'admin-select';
        select.dataset.fieldType = fieldType;
        select.dataset.fieldKey = fieldKey;
        select.dataset.index = String(index);

        const emptyOption = document.createElement('option');
        emptyOption.value = '';
        emptyOption.textContent = 'Sin definir';
        select.appendChild(emptyOption);

        countries.forEach((country) => {
          const option = document.createElement('option');
          option.value = country.code;
          option.textContent = `${country.flag} ${country.name}`;
          select.appendChild(option);
        });

        select.value = value ?? '';
        return select;
      };

      const createSlot = (labelText, select) => {
        const wrapper = createNode('label', 'admin-slot');
        const label = createNode('span', 'admin-slot-label', labelText);

        wrapper.appendChild(label);
        wrapper.appendChild(select);
        return wrapper;
      };

      const createGroupCard = (groupName, values) => {
        const card = createNode('article', 'admin-stage-card');
        card.appendChild(createNode('h3', 'admin-stage-title', groupName));

        const grid = createNode('div', 'admin-slot-grid');

        for (let index = 0; index < 4; index += 1) {
          const select = createSelect(values?.[index] ?? '', 'group', groupName, index);
          grid.appendChild(createSlot(`${index + 1}°`, select));
        }

        card.appendChild(grid);
        return card;
      };

      const createKnockoutCard = (stage, values) => {
        const card = createNode('article', 'admin-stage-card');
        card.appendChild(createNode('h3', 'admin-stage-title', stage.label));

        const grid = createNode('div', 'admin-slot-grid admin-slot-grid--knockout');

        for (let index = 0; index < stage.size; index += 1) {
          const select = createSelect(values?.[index] ?? '', 'knockout', stage.key, index);
          grid.appendChild(createSlot(String(index + 1), select));
        }

        card.appendChild(grid);
        return card;
      };

      const renderEditors = () => {
        if (!groupsEditor || !knockoutEditor || !officialResults) {
          return;
        }

        groupsEditor.innerHTML = '';
        knockoutEditor.innerHTML = '';

        const groupsFragment = document.createDocumentFragment();
        GROUPS.forEach((groupName) => {
          groupsFragment.appendChild(createGroupCard(groupName, officialResults.groupOrder?.[groupName] ?? []));
        });
        groupsEditor.appendChild(groupsFragment);

        const knockoutFragment = document.createDocumentFragment();
        KNOCKOUT_STAGES.forEach((stage) => {
          knockoutFragment.appendChild(createKnockoutCard(stage, officialResults.knockout?.[stage.key] ?? []));
        });
        knockoutEditor.appendChild(knockoutFragment);
      };

      const setStatus = (message, isError = false) => {
        if (!statusLabel) {
          return;
        }

        statusLabel.textContent = message;
        statusLabel.dataset.state = isError ? 'error' : 'ready';
      };

      const setSaveEnabled = (enabled) => {
        if (saveButton) {
          saveButton.disabled = !enabled;
        }
      };

      const normalizeGroupOrder = () => {
        const result = {};

        GROUPS.forEach((groupName) => {
          const selects = document.querySelectorAll(`select[data-field-type="group"][data-field-key="${groupName}"]`);
          result[groupName] = Array.from(selects).map((select) => select.value || null);
        });

        return result;
      };

      const normalizeKnockout = () => {
        const result = {};

        KNOCKOUT_STAGES.forEach((stage) => {
          const selects = document.querySelectorAll(`select[data-field-type="knockout"][data-field-key="${stage.key}"]`);
          result[stage.key] = Array.from(selects).map((select) => select.value || null);
        });

        return result;
      };

      const updateFromForm = () => {
        if (!officialResults) {
          return;
        }

        officialResults = {
          ...officialResults,
          groupOrder: normalizeGroupOrder(),
          knockout: normalizeKnockout(),
        };
      };

      const bindChangeHandlers = () => {
        document.querySelectorAll('select[data-field-type]').forEach((select) => {
          select.addEventListener('change', () => {
            updateFromForm();
            setSaveEnabled(Boolean(sessionUser?.discordId));
          });
        });
      };

      const loadSession = async () => {
        try {
          const response = await fetch(`${API_URL}/auth/me`, {
            headers: getAuthHeaders(),
            credentials: 'include',
          });

          if (!response.ok) {
            sessionUser = null;
            return;
          }

          const data = await response.json();
          sessionUser = data?.user ?? null;
        } catch {
          sessionUser = null;
        }
      };

      const loadCountries = async () => {
        const response = await fetch(`${API_URL}/api/countries`);

        if (!response.ok) {
          throw new Error('No se pudieron cargar los países.');
        }

        const data = await response.json();
        countries = Array.isArray(data) ? data : [];
      };

      const loadOfficialResults = async () => {
        const response = await fetch(`${API_URL}/api/official-results`);

        if (!response.ok) {
          throw new Error('No se pudieron cargar los resultados oficiales.');
        }

        const data = await response.json();
        officialResults = data?.officialResults ?? null;
      };

      const verifyAccess = () => {
        const isAdmin = sessionUser?.discordId === ADMIN_DISCORD_ID;

        if (!isAdmin) {
          if (board) {
            board.hidden = true;
          }

          setSaveEnabled(false);
          setStatus('Acceso restringido. Esta ruta es solo para el usuario admin.', true);
          return false;
        }

        if (board) {
          board.hidden = false;
        }

        setSaveEnabled(true);
        setStatus('Acceso concedido. Ya puedes editar los resultados oficiales.');
        return true;
      };

      const saveResults = async () => {
        if (!sessionUser?.discordId || sessionUser.discordId !== ADMIN_DISCORD_ID) {
          setStatus('No tienes permiso para guardar estos cambios.', true);
          return;
        }

        updateFromForm();

        setSaveEnabled(false);

        try {
          const response = await fetch(`${API_URL}/api/official-results`, {
            method: 'PUT',
            headers: {
              'Content-Type': 'application/json',
              ...getAuthHeaders(),
            },
            credentials: 'include',
            body: JSON.stringify({
              groupOrder: officialResults?.groupOrder ?? {},
              knockout: officialResults?.knockout ?? {},
            }),
          });

          if (!response.ok) {
            let errorMessage = 'No se pudieron guardar los resultados oficiales.';

            try {
              const errorBody = await response.json();
              errorMessage = errorBody?.message || errorMessage;
            } catch {
              // Keep fallback message.
            }

            throw new Error(errorMessage);
          }

          const data = await response.json();
          officialResults = data?.officialResults ?? officialResults;
          renderEditors();
          bindChangeHandlers();
          try {
            const channel = new BroadcastChannel('penca-results');
            channel.postMessage({ type: 'official-results-updated' });
            channel.close();
          } catch {
            // Ignore broadcast failures and rely on polling.
          }
          setStatus('Resultados oficiales guardados correctamente.');
        } catch (error) {
          const message = error instanceof Error ? error.message : 'Error inesperado al guardar los resultados.';
          setStatus(message, true);
        } finally {
          setSaveEnabled(Boolean(sessionUser?.discordId) && sessionUser.discordId === ADMIN_DISCORD_ID);
        }
      };

      const initialize = async () => {
        try {
          await loadSession();

          if (!verifyAccess()) {
            return;
          }

          await Promise.all([loadCountries(), loadOfficialResults()]);
          renderEditors();
          bindChangeHandlers();
          setSaveEnabled(true);
        } catch (error) {
          const message = error instanceof Error ? error.message : 'No se pudo cargar el panel admin.';
          setStatus(message, true);
        }
      };

      if (saveButton) {
        saveButton.addEventListener('click', saveResults);
      }

      initialize();
    })();
  </script>
</Layout>

<style>
  .admin-shell {
    max-width: 1320px;
    margin: 0 auto;
    padding: 28px 20px 40px;
  }

  .admin-hero {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 20px;
    margin-bottom: 18px;
  }

  .eyebrow {
    margin: 0 0 6px;
    text-transform: uppercase;
    letter-spacing: 0.16em;
    font-size: 12px;
    color: #67e8f9;
  }

  h1 {
    margin: 0;
    font-size: clamp(34px, 4vw, 54px);
  }

  .admin-copy {
    margin: 10px 0 0;
    max-width: 760px;
    color: var(--muted);
    font-size: 16px;
  }

  .admin-hero-actions {
    display: flex;
    align-items: center;
    gap: 12px;
    flex-wrap: wrap;
  }

  .back-link,
  .save-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 44px;
    padding: 0 16px;
    border-radius: 12px;
    border: 1px solid rgba(255, 255, 255, 0.08);
    text-decoration: none;
    font-weight: 700;
    font-size: 14px;
    transition: 0.2s ease;
  }

  .back-link {
    color: #e2e8f0;
    background: rgba(15, 23, 42, 0.56);
  }

  .save-button {
    color: white;
    background: linear-gradient(135deg, #0f766e, #14b8a6);
    border-color: rgba(20, 184, 166, 0.3);
    cursor: pointer;
  }

  .save-button:disabled {
    cursor: not-allowed;
    opacity: 0.55;
  }

  .back-link:hover,
  .save-button:hover:not(:disabled) {
    transform: translateY(-2px);
  }

  .admin-status {
    margin-bottom: 20px;
    padding: 14px 16px;
    border-radius: 14px;
    border: 1px solid rgba(255, 255, 255, 0.08);
    background: rgba(15, 23, 42, 0.55);
    color: #cbd5e1;
  }

  .admin-status[data-state='error'] {
    border-color: rgba(239, 68, 68, 0.32);
    background: rgba(127, 29, 29, 0.2);
    color: #fecaca;
  }

  .admin-board {
    display: grid;
    gap: 20px;
  }

  .admin-card {
    padding: 20px;
    border-radius: 20px;
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(255, 255, 255, 0.08);
    box-shadow: 0 18px 40px rgba(2, 6, 23, 0.18);
  }

  .card-heading {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    margin-bottom: 16px;
    flex-wrap: wrap;
  }

  .card-heading h2 {
    margin: 0;
  }

  .card-hint {
    color: var(--muted);
    font-size: 13px;
  }

  .group-editor,
  .knockout-editor {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 14px;
  }

  .admin-stage-card {
    padding: 14px;
    border-radius: 16px;
    background: rgba(15, 23, 42, 0.55);
    border: 1px solid rgba(255, 255, 255, 0.08);
  }

  .admin-stage-title {
    margin: 0 0 12px;
    font-size: 16px;
  }

  .admin-slot-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 10px;
  }

  .admin-slot-grid--knockout {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .admin-slot {
    display: grid;
    gap: 6px;
  }

  .admin-slot-label {
    color: #cbd5e1;
    font-size: 12px;
    font-weight: 700;
  }

  .admin-select {
    width: 100%;
    min-width: 0;
    border-radius: 12px;
    border: 1px solid rgba(255, 255, 255, 0.1);
    background: rgba(2, 6, 23, 0.62);
    color: #e2e8f0;
    padding: 10px 12px;
    font-size: 14px;
  }

  .admin-select:focus {
    outline: 2px solid rgba(34, 211, 238, 0.35);
    outline-offset: 2px;
  }

  @media (max-width: 760px) {
    .admin-hero {
      align-items: flex-start;
      flex-direction: column;
    }

    .group-editor,
    .knockout-editor {
      grid-template-columns: 1fr;
    }

    .admin-slot-grid,
    .admin-slot-grid--knockout {
      grid-template-columns: 1fr;
    }
  }
</style>